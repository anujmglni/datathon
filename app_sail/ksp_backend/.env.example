# ==============================================================================
# KARNATAKA STATE POLICE (KSP) CATALYST INTELLIGENCE PLATFORM — ENV TEMPLATE
# Copy this file to .env in app_sail/ksp_backend/
# ==============================================================================

# ── AI & LLM PROVIDER CONFIGURATION ───────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── POSTGRESQL DATABASE CONFIGURATION ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ksp_db
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres
PG_DATABASE=ksp_db

# ── ZOHO CATALYST & ZIA AI CONFIGURATION ──────────────────────────────────────
ZOHO_CATALYST_PROJECT_ID=45688000000013023
ZOHO_CATALYST_API_URL=https://catalyst.zoho.com/baas/v1/projects/45688000000013023
ZIA_OCR_API_URL=https://catalyst.zoho.com/baas/v1/projects/45688000000013023/ml/ocr

# ── BACKEND SERVER CONFIGURATION ──────────────────────────────────────────────
PORT=8080
HOST=0.0.0.0
ENVIRONMENT=development
